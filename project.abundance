      "interpreterVersion": 1,
      "code": "function run(\n  shape: Assembly,\n  edgeIndexes: number[] = [0]) {\n  let result: replicad.Edge[] = [];\n  shape.onLeafs((leaf) => {\n    let edges = []\n    if (leaf.geometry instanceof replicad.Drawing) {\n      const sketches = leaf.geometry.sketchOnPlane(leaf.plane)\n      let faces = []\n      if (sketches instanceof replicad.Sketches) {\n        const t = sketches.faces()\n        faces = t instanceof replicad.Face ? [t] : t.faces\n      } else {\n        faces = [sketches.face()]\n      }\n      edges = faces.map((f) => f.edges).flat()\n    } else {\n      edges = leaf.geometry.edges\n    }\n    result.push(...\n      edgeIndexes.filter((i) => i >= 0 && i < edges.length).map((i) => {\n        edges[i]\n      }))\n    edgeIndexes = edgeIndexes.map((i) => i - edges.length)\n  })\n  return result.map(replicad.assembleWire);\n}\n",
      "compiledCode": "\"use strict\";\nfunction run(shape, edgeIndexes = [0]) {\n    let result = [];\n    shape.onLeafs((leaf) => {\n        let edges = [];\n        if (leaf.geometry instanceof replicad.Drawing) {\n            const sketches = leaf.geometry.sketchOnPlane(leaf.plane);\n            let faces = [];\n            if (sketches instanceof replicad.Sketches) {\n                const t = sketches.faces();\n                faces = t instanceof replicad.Face ? [t] : t.faces;\n            }\n            else {\n                faces = [sketches.face()];\n            }\n            edges = faces.map((f) => f.edges).flat();\n        }\n        else {\n            edges = leaf.geometry.edges;\n        }\n        result.push(...edgeIndexes.filter((i) => i >= 0 && i < edges.length).map((i) => {\n            edges[i];\n        }));\n        edgeIndexes = edgeIndexes.map((i) => i - edges.length);\n    });\n    return result.map(replicad.assembleWire);\n}\n"
    },
    {
      "atomType": "Code",
      "x": 0.490625,
      "y": 0.7094155844155845,
      "uniqueID": "id-68",
      "ioValues": [
        {
          "name": "width",
